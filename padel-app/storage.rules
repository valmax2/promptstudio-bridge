rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{uid}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Catalogo condiviso di avatar/cornici custom (vedi js/admin.js e
    // firestore.rules) - le immagini vere e proprie vivono qui in Storage,
    // separate dai metadati (label, url) in Firestore; solo l'admin può
    // caricarle, tutti gli utenti autenticati possono leggerle.
    match /admin-customAvatars/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == 'CAvv7ICUfYYpqcCRjA7s3ZhsoGo2'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /admin-customFrames/{itemId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == 'CAvv7ICUfYYpqcCRjA7s3ZhsoGo2'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
