<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        NESSUN android.permission.INTERNET qui: la build "offline" (quella da distribuire
        realmente) non puo' comunicare in rete. Il flavor "devTools" aggiunge INTERNET
        solo per lo sviluppo (vedi app/src/devTools/AndroidManifest.xml) e non deve mai
        essere usato per la release pubblica.
    -->

    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <!-- Richiesto solo su Android 13+ per la notifica di avanzamento import/checksum in background. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Nessuna feature GPU/Vulkan obbligatoria: la diagnostica hardware la rileva a runtime
         e degrada automaticamente al profilo Base se assente. -->
    <uses-feature
        android:name="android.hardware.vulkan.level"
        android:required="false" />

    <application
        android:name=".AiCreatorApplication"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AiCreatorOffline"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:extractNativeLibs="true"
        tools:targetApi="34">

        <!--
            largeHeap: la generazione di immagini on-device alloca buffer intermedi grandi
            (tensori/latents). Il DeviceCapabilityAnalyzer verifica comunque la RAM disponibile
            prima di ogni generazione e riduce automaticamente risoluzione/passi se necessario.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AiCreatorOffline.Splash"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WorkManager: solo lavori locali (import modello, checksum, pulizia file temporanei). -->
        <provider
            android:name="androidx.work.impl.WorkManagerInitializer"
            android:authorities="${applicationId}.workmanager-init"
            android:exported="false"
            tools:node="remove" />

    </application>

</manifest>
