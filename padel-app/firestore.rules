rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isMe(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Ogni utente gestisce il proprio profilo; è leggibile da tutti gli
    // utenti autenticati per poter cercare amici per codice personale.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isMe(uid);

      match /friends/{friendUid} {
        allow read: if isMe(uid);
        allow write: if isMe(uid) || isMe(friendUid);
      }
    }

    // I gruppi ("circles" nel codice) sono visibili solo ai membri; ci si
    // può unire conoscendo il codice (id del documento) o essere aggiunti
    // direttamente da un membro; un membro può anche rimuovere solo se
    // stesso (uscire dal gruppo); solo il proprietario può eliminarlo.
    match /circles/{circleId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.ownerId == resource.data.ownerId && (
        request.auth.uid in request.resource.data.memberIds ||
        (request.auth.uid in resource.data.memberIds
          && resource.data.memberIds.removeAll([request.auth.uid]) == request.resource.data.memberIds)
      );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Gli eventi sono leggibili da chi è stato invitato (host incluso); le
    // risposte RSVP possono modificare solo la propria voce in
    // "participants"; solo l'organizzatore può modificarne il resto o
    // eliminarlo.
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.hostId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
      );
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;
    }

    // Le partite sono private a chi le ha registrate.
    match /matches/{matchId} {
      allow read: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // Chat 1:1 tra due amici: id documento = i due uid ordinati e uniti da
    // "_", quindi solo i due partecipanti possono leggerla/scriverla.
    function isChatParticipant(chatId) {
      return request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && isChatParticipant(chatId);
        allow create: if isSignedIn() && isChatParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
